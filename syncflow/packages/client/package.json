{
  "name": "syncflow-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:peer": "vite --host 127.0.0.1 --port 1421 --strictPort",
    "dev:tauri:peer": "powershell -NoProfile -Command \"$env:SYNCFLOW_PROFILE='b'; $env:SYNCFLOW_DEVICE_NAME='PC-B'; $env:SYNCFLOW_SDP_PORT='18081'; $env:CARGO_TARGET_DIR=(Resolve-Path ..\\..\\..\\.tmp\\syncflow-target-b).Path; npx tauri dev --config src-tauri/tauri.peer.conf.json\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^5"
  }
}
